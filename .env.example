# ═══════════════════════════════════════════
# OpenPortal — Environment Variables
# Copy this to .env.local and fill in values
# ═══════════════════════════════════════════

# ── Database ──────────────────────────────
DATABASE_URL=postgresql://openportal:openportal_dev@localhost:5432/openportal

# ── Redis ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API Server ────────────────────────────
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── JWT ───────────────────────────────────
JWT_SECRET=openportal-dev-secret-change-this-in-production-use-64-chars-min

# ── Object Storage (MinIO / S3) ──────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=openportal
S3_SECRET_KEY=openportal_dev
S3_BUCKET_DOCUMENTS=documents
S3_BUCKET_AVATARS=avatars
S3_REGION=us-east-1

# ── Search (Meilisearch) ─────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=openportal_search_dev_key

# ── Email (Mailpit for dev) ──────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@openportal.local
MAIL_FROM_NAME=OpenPortal
MAIL_FROM_EMAIL=noreply@openportal.app

# ── Anthropic (Claude API for chat widget) ─
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# ── Frontend ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=OpenPortal
