# ═══════════════════════════════════════════════
# OpenPortal — Production Environment Variables
# Copy to .env and update all values marked CHANGE
# ═══════════════════════════════════════════════

# ─── Database ───
DATABASE_URL=postgresql://openportal:CHANGE_DB_PASSWORD@localhost:5432/openportal
DB_PASSWORD=CHANGE_DB_PASSWORD

# ─── Redis ───
REDIS_URL=redis://:CHANGE_REDIS_PASSWORD@localhost:6379
REDIS_PASSWORD=CHANGE_REDIS_PASSWORD

# ─── S3 / MinIO ───
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=openportal
S3_SECRET_KEY=CHANGE_MINIO_PASSWORD
S3_BUCKET_DOCUMENTS=documents
S3_REGION=us-east-1

# ─── Meilisearch ───
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=CHANGE_MEILI_KEY

# ─── JWT ───
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_STRING_MINIMUM

# ─── API ───
API_PORT=4000
CORS_ORIGIN=https://your-domain.com

# ─── Web ───
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# ─── Email (Production) ───
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=CHANGE_SMTP_KEY
SMTP_FROM=noreply@your-domain.com

# ─── Email (Development — Mailpit) ───
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=dev@openportal.local
