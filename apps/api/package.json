{
  "name": "@openportal/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@openportal/db": "workspace:*",
    "@openportal/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "zod": "^3.24.1",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "dayjs": "^1.11.13",
    "nodemailer": "^6.9.16",
    "@anthropic-ai/sdk": "^0.32.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
